# ============================================================================
#  Webuy OPS Center — environment variables
#
#  Set these in Vercel project settings AND in a local .env for testing.
#  The local .env is git-ignored — never commit real values.
#  Sections: [core] always needed · [sync/cron] · [quote tool] · [data MCP] · [auto]
# ============================================================================

# ── [core] Supabase ─────────────────────────────────────────────────────────
# SUPABASE_URL + anon key are read by the browser (anon key lives in app.html).
# SERVICE_ROLE_KEY bypasses RLS — server-side only, NEVER expose to the browser.
SUPABASE_URL=https://vnjdlxgwdgofghqjvxqp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__set_me__

# SUPABASE_DB_URL — direct Postgres connection for supabase/*.mjs migration tools
#   (apply-migration.mjs, local-run.mjs). NOT used by the deployed app.
#   The direct host db.<ref>.supabase.co is IPv6-only and won't resolve on most
#   IPv4 networks — use the Session pooler (IPv4) instead. Note the username
#   becomes postgres.<project-ref> and newer projects use the aws-1- prefix:
#   postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
#   This project: region=ap-southeast-1, ref=vnjdlxgwdgofghqjvxqp.
SUPABASE_DB_URL=__set_me__

# ── [sync/cron] Skybar (Indonesia) production MySQL — read-only account ──────
SKYBAR_MYSQL_HOST=idprod.tourt.mysql.webuy.ren
SKYBAR_MYSQL_PORT=3315
SKYBAR_MYSQL_USER=webuy_query
SKYBAR_MYSQL_PASS=__set_me__
SKYBAR_MYSQL_DB=webuy_tourt

# ── [sync/cron] Sync endpoint auth ──────────────────────────────────────────
# CRON_SECRET: Vercel auto-attaches "Authorization: Bearer <CRON_SECRET>" to cron
#   invocations when this env var is set. Use a long random string.
CRON_SECRET=__set_me__
# SYNC_SECRET: optional shared secret for manual/local triggers via the
#   "x-sync-secret" header (the in-app button uses the logged-in user's Supabase
#   token instead, so this is mainly for curl/local testing).
SYNC_SECRET=__set_me__

# ── [quote tool] AI itinerary quote generator (api/quote-generate, quote-render) ─
# ANTHROPIC_API_KEY: required for AI extraction + scenery-photo vision picks.
ANTHROPIC_API_KEY=__set_me__
# PEXELS_API_KEY: stock-photo fallback when the itinerary has no usable images.
PEXELS_API_KEY=__set_me__
# Optional tuning (defaults shown; leave unset to use the default):
QUOTE_MODEL=claude-sonnet-4-6        # Anthropic model id for extraction
QUOTE_AI_TIMEOUT_MS=45000            # per-call AI timeout (min 3000)
QUOTE_USE_AI=1                       # set to 0 to disable AI extraction
QUOTE_MOCK=0                         # set to 1 to return a canned mock quote
QUOTE_EXTRACT_DOCX_IMAGES=0          # set to 1 to pull images out of the .docx
QUOTE_ALLOW_PEXELS_FALLBACK=1        # set to 0 to disable the Pexels fallback
QUOTE_FX_RATE=2700                   # default FX (IDR per source unit)
QUOTE_PROFIT=                        # default markup (blank = none)
QUOTE_ROUND=50000                    # price rounding step (IDR)
# WEBUY_ITINERARY_MCP_URL: itinerary MCP base (default points at the hosted one).
# WEBUY_ITINERARY_MCP_URL=https://webuy-itinerary-mcp.onrender.com

# ── [data MCP] Webuy 数据中台 — server-side only, for id-intelligence / id-crm ─
# Prefer token-only in Vercel env; the API builds the URL server-side.
WEBUY_DATA_MCP_TOKEN=__set_me__
# Or full URL if needed:
# WEBUY_DATA_MCP_URL=https://webuy-data-platform.onrender.com/mcp?token=__set_me__

# ── [auto] Injected by Vercel at runtime — do NOT set manually ───────────────
# VERCEL=1, VERCEL_URL=<deployment-host> are provided by the platform.
