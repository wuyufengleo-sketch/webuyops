{
  "version": 2,
  "name": "webuy-ops",
  "functions": {
    "api/auth.js": { "maxDuration": 10 },
    "api/visa.js": { "maxDuration": 15 },
    "api/sync-skybar.js": { "maxDuration": 60 },
    "api/quote-generate.js": { "maxDuration": 300 },
    "api/quote-render.js": { "maxDuration": 90 },
    "api/quote-get.js": { "maxDuration": 10 },
    "api/flight-quotes.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/sync-skybar", "schedule": "0 11 * * *" }
  ],
  "rewrites": [
    { "source": "/api/auth",                "destination": "/api/auth.js" },
    { "source": "/api/visa",                "destination": "/api/visa.js" },
    { "source": "/api/sync-skybar",         "destination": "/api/sync-skybar.js" },
    { "source": "/api/data-platform-check", "destination": "/api/data-platform-check.js" },
    { "source": "/api/quote-generate",      "destination": "/api/quote-generate.js" },
    { "source": "/api/quote-render",        "destination": "/api/quote-render.js" },
    { "source": "/api/quote-get",           "destination": "/api/quote-get.js" },
    { "source": "/api/flight-quotes",       "destination": "/api/flight-quotes.js" },
    { "source": "/api/crm-audiences/summary", "destination": "/api/id-crm.js?audience=summary" },
    { "source": "/api/crm-audiences/presets", "destination": "/api/id-crm.js?audience=presets" },
    { "source": "/api/crm-audiences/preview", "destination": "/api/id-crm.js?audience=preview" },
    { "source": "/api/crm-audiences/export",  "destination": "/api/id-crm.js?audience=export" },
    { "source": "/api/crm-tags",              "destination": "/api/id-crm.js?audience=tags" },
    { "source": "/api/crm-campaigns/dormant-match", "destination": "/api/id-crm.js?audience=dormant-match" },
    { "source": "/api/crm-campaigns",        "destination": "/api/id-crm.js?audience=campaigns" },
    { "source": "/api/crm-campaigns/create", "destination": "/api/id-crm.js?audience=campaign-create" },
    { "source": "/api/crm-campaigns/update", "destination": "/api/id-crm.js?audience=campaign-update" },
    { "source": "/q",                       "destination": "/quote.html" },
    { "source": "/app",                     "destination": "/app.html" },
    { "source": "/",                        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/app",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
